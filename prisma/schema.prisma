generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id    String @id
  name  String
  phone String
  email String

  city          String?
  pickupPoint   String?
  pickupAddress String?

  amount        Float
  paymentStatus String @default("pending")
  cdekOrderId   String?
  trackingNumber String?

  createdAt DateTime @default(now())

  items OrderItem[]
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId String

  name     String
  size     String
  quantity Int
  price    Float

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
